# =============================================================================
# .env.example — 環境変数テンプレート
# =============================================================================
# コピーして .env にリネームし、各値を環境に合わせて書き換えてください。
#   cp .env.example .env
#
# 【変数名の命名規則】
#   DEVICE_*       : NETCONF 接続先デバイス（SSH / ポート 830）
#   EAPI_*         : eAPI 接続先デバイス（HTTPS / ポート 443）
#   *_A2A_URL      : 各 A2A マイクロサービスの内部 URL
#   AZURE_OPENAI_* : Azure OpenAI API 認証情報
# =============================================================================


# -----------------------------------------------------------------------------
# [1] NETCONF 接続先デバイス
#     使用: arista_netconf_rag_a2a_server.py / app_a2a.py
# -----------------------------------------------------------------------------
DEVICE_IP=192.168.1.1
DEVICE_PORT=830
DEVICE_USER=admin
DEVICE_PASS=your_password


# -----------------------------------------------------------------------------
# [2] eAPI 接続先デバイス（Arista EOS HTTP/HTTPS API）
#     使用: arista_eapi_show / arista_eapi_config / arista_anta_verify / diagnose
# -----------------------------------------------------------------------------
EAPI_HOST=192.168.1.1
EAPI_PORT=443
EAPI_TRANSPORT=https
EAPI_USER=admin
EAPI_PASS=your_password

# enable モードのパスワード（不要な場合は空のまま）
EAPI_ENABLE_PASS=your_password

# 自己署名証明書を許可する場合は true（本番環境では false 推奨）
EAPI_INSECURE=true


# -----------------------------------------------------------------------------
# [3] A2A マイクロサービス — 内部 URL
#     各サーバーのデフォルトポートは起動スクリプト側で設定済み。
#     Docker Compose 等でホスト名が変わる場合に上書き。
#     使用: task_decompose_a2a_server.py / app_a2a.py
# -----------------------------------------------------------------------------
# Hub（task_decompose）
API_BASE=http://localhost:8000
WS_BASE=ws://localhost:8000
TASK_DECOMPOSE_URL=http://localhost:8000

# 各エージェント
NETCONF_A2A_URL=http://localhost:8001
EAPI_A2A_URL=http://localhost:8002
XDP_A2A_URL=http://localhost:8003
ANTA_A2A_URL=http://localhost:8004
DIAGNOSE_A2A_URL=http://localhost:8005
EAPI_CONFIG_A2A_URL=http://localhost:8006

# eAPI session-diff REST サービス（arista_eapi_show が内部公開）
EAPI_SDIFF_URL=http://localhost:8009

# XDP — Go IPS バックエンド
XDP_API_URL=http://localhost:8080

# app_a2a.py が公開するポート（Go IPS が 8080 を占有するため 8088 がデフォルト）
PORT=8088


# -----------------------------------------------------------------------------
# [4] A2A サーバー共通設定
#     A2A_HOST / A2A_PORT / A2A_PUBLIC_URL は各サーバーごとに独立して読む。
#     通常はデフォルト値のまま変更不要。外部ロードバランサー経由の場合に設定。
# -----------------------------------------------------------------------------
# A2A_HOST=0.0.0.0
# A2A_PORT=8000          # サーバーごとに異なるため、各サービスのデフォルトに従う
# A2A_PUBLIC_URL=http://your-domain.example.com:8000


# -----------------------------------------------------------------------------
# [5] LLM プロバイダー
#     使用: llm_factory.py（全サーバーから import）
# -----------------------------------------------------------------------------
# プロバイダー選択: auto（自動） / groq / azure
LLM_PROVIDER=auto

# LLM API タイムアウト（秒）
LLM_TIMEOUT=30

# --- Groq ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-03-01-preview


# -----------------------------------------------------------------------------
# [6] ファイル・ストレージパス
#     使用: llm_factory.py / arista_netconf_rag / arista_eapi_show / snapshot_manager
# -----------------------------------------------------------------------------
# config.ini のパス（LLM プロバイダー設定ファイル）
# SASE_CONFIG=./config.ini

# FAISS ベクターDB のパス（RAG 用）
# FAISS_PATH=./faiss_db/arista_netconf

# ANTA スナップショット保存先（arista_anta_verify）
# SNAPSHOT_STORE=./anta_snapshots

# 監査ログ出力先（空文字列 = stdout）
# AUDIT_LOG_PATH=./audit_log_arista.jsonl

# 操作ポリシー YAML（存在しない場合はデフォルトで自動生成）
# POLICY_YAML_PATH=./policy_arista.yaml


# -----------------------------------------------------------------------------
# [7] アプリ全般
#     使用: app_a2a.py
# -----------------------------------------------------------------------------
# HTTP リクエストのタイムアウト（秒）
HTTP_TIMEOUT=120

# Basic 認証（カンマ区切りで複数ユーザー指定可能）
#   例: BASIC_AUTH_USER=admin,judge2
BASIC_AUTH_USER=judge
BASIC_AUTH_PASS=hackathon2026

# レートリミット（リクエスト / 分）
RATE_LIMIT_RPM=30

# 表示言語: ja（日本語）/ en（英語）
LOCALE=ja

